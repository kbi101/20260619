# QuantStation EditorConfig
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.java]
indent_size = 4

[*.{ts,tsx,js,jsx,css,json,yml,yaml,md}]
indent_size = 2

[*.{gradle,gradle.kts}]
indent_size = 4

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2
