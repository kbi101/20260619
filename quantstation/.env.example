# QuantStation — Environment Variables Template
# Copy to .env and fill in your credentials

# ── IB Gateway Credentials ────────────────────────────
TWS_USERID=
TWS_PASSWORD=
TRADING_MODE=paper
READ_ONLY_API=false
VNC_PASSWORD=quantstation

# ── Alpha Vantage ─────────────────────────────────────
ALPHA_VANTAGE_API_KEY=

# ── Massive.com (ex-Polygon.io) — Future ──────────────
MASSIVE_API_KEY=

# ── Spring Boot ───────────────────────────────────────
SPRING_PROFILES_ACTIVE=paper
